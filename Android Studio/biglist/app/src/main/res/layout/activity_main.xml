<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <include
        android:id="@+id/tool"
        layout="@layout/head"/>

    <ScrollView
        android:id="@+id/scrollview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="55dp"
        android:layout_below="@+id/tool"
        android:background="#F2F4F6"
        android:paddingLeft="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:background="@color/white"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp">
                    <TextView
                        android:id="@+id/textView3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Distributer  "
                        android:textSize="10dp" />
                    <TextView
                        android:textColor="#FF0000"
                        android:text="*"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>


                </LinearLayout>


                <AutoCompleteTextView
                    android:id="@+id/disributor"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:drawableStart="@drawable/search"
                    android:hint="Search By Distributor Name"
                    android:textSize="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/textView2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Beat   "
                        android:textSize="10dp" />
                    <TextView
                        android:textColor="#FF0000"
                        android:text="*"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>


                </LinearLayout>


                <AutoCompleteTextView
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:drawableStart="@drawable/search"
                    android:id="@+id/beat"
                    android:hint="Serach By Beat Name"
                    android:textSize="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/o"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Outlet   "
                        android:textSize="10dp" />
                    <TextView
                        android:textColor="#FF0000"
                        android:text="*"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>


                </LinearLayout>


                <AutoCompleteTextView
                    android:id="@+id/outlet"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:drawableStart="@drawable/search"
                    android:hint="Search Outlet"
                    android:textSize="12dp" />

                <Button
                    android:id="@+id/button"
                    android:layout_width="200dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center_horizontal"
                    android:text="Add Outlet" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:background="@color/white">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:paddingTop="10dp"
                        android:layout_weight="1"
                        android:text="Outlet Information" />

                    <ImageView
                        android:layout_width="35dp"
                        android:layout_height="30dp"
                        android:layout_marginTop="10dp"
                        android:background="#F2F4F6"
                        android:src="@drawable/clipboard" />




            </LinearLayout>

            <LinearLayout
                android:background="@color/white"
                android:layout_width="match_parent"
                android:layout_height="50dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:paddingLeft="6dp"
                    android:layout_gravity="center"
                    android:src="@drawable/location"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="1"/>

                    <ImageView
                        android:id="@+id/phone"
                        android:layout_width="35dp"
                        android:layout_height="30dp"
                        android:padding="4dp"
                        android:layout_gravity="center"
                        android:background="#F2F4F6"
                        android:paddingLeft="6dp"
                        android:src="@drawable/phone" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/purpose"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:visibility="visible">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="#e0e0e0"
                        android:padding="5dp"
                        android:paddingBottom="5dp"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <LinearLayout
                            android:layout_width="190dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/buttonshape">

                            <TextView
                                android:id="@+id/cancel"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="CANCEL" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginLeft="10dp"
                            android:background="@drawable/addbutton">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="ADD"
                                android:textColor="#ffffff" />
                        </LinearLayout>


                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="12dp"
                        android:layout_weight="1"
                        android:text="Purpose of the visit"/>

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/notepad" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <CheckBox
                            android:id="@+id/checkboxsupply"
                            android:text="Supply"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"/>
                        <CheckBox
                            android:id="@+id/checkboxcurrent"
                            android:text="Current Stock"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"/>

                        <CheckBox
                            android:id="@+id/checkboxgeneral"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:text="General Visit" />
                        <TextView
                            android:layout_marginLeft="6dp"
                            android:textStyle="normal"
                            android:textSize="8dp"
                            android:text="(multiple selection allowed)"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>

                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@color/white"
                        android:orientation="vertical">

                        <CheckBox
                            android:id="@+id/checkboxtake"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:text="Take Order"/>
                        <CheckBox
                            android:id="@+id/checkboxreturn"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:text="Return"/>
                        <CheckBox
                            android:id="@+id/checkboxcollection"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:text="Collection"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/supply"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@color/white"
                android:orientation="vertical"
                android:visibility="visible">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="10dp"
                        android:text="Supply Details" />

                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@color/white">
                    <TextView
                        android:layout_height="match_parent"
                        android:layout_width="match_parent"
                        android:layout_marginLeft="5dp"
                        android:layout_marginTop="13dp"
                        android:textSize="8dp"
                        android:layout_weight="1"
                        android:text="Supply Amount   " />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#FF0000"
                        android:text="*" />
                    <EditText
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_weight="0.5"
                        android:layout_marginBottom="15dp"/>

                </LinearLayout>

            </LinearLayout>


            <LinearLayout
                android:visibility="visible"
                android:id="@+id/take"
                android:orientation="vertical"
                android:layout_marginTop="15dp"
                android:background="@color/white"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_marginTop="10dp"
                    android:text="Order Details"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"/>

                <LinearLayout
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="35dp">

                        <TextView
                            android:textColor="#5C4080"
                            android:id="@+id/outletorder"
                            android:background="@drawable/shape"
                            android:layout_width="175dp"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="Outlet Order"
                            android:textSize="8dp" />

                        <TextView
                            android:textColor="#5C4080"
                            android:id="@+id/phoneorder"
                            android:background="@drawable/textviewbgcolor"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="Phone Order"
                            android:textSize="8dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_marginTop="1dp"
                    android:layout_width="match_parent"
                    android:layout_height="30dp">
                    <TextView
                        android:layout_marginTop="10dp"
                        android:textSize="9dp"
                        android:text="Order Distributor Name"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>

                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="35dp">

                    <AutoCompleteTextView
                        android:id="@+id/distributorname"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:drawableStart="@drawable/search"
                        android:textSize="12dp" />
                </LinearLayout>

                    <CheckBox
                        android:id="@+id/checkboxordervisible"
                        android:text="Order Delivery"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"/>
                <LinearLayout
                    android:id="@+id/ordervisible"
                    android:orientation="vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textSize="8dp"
                            android:text="Delivery Date   "
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:textColor="#FF0000"
                            android:text="*"
                            android:layout_width="130dp"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:textSize="8dp"
                            android:text="Vehicle No   "
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:textColor="#FF0000"
                            android:text="*"
                            android:layout_width="125dp"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_marginTop="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="200dp"
                            android:layout_height="match_parent">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_marginTop="10dp"
                                    android:paddingLeft="6dp"
                                    android:src="@drawable/calendar"/>

                                <TextView
                                    android:paddingLeft="5dp"
                                    android:paddingTop="13dp"
                                    android:hint="dd-mm-yyyy"
                                    android:id="@+id/deliverydate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="35dp" />
                            </LinearLayout>

                            <TextView
                                android:background="@color/black"
                                android:layout_width="190dp"

                                android:layout_height="1dp"/>
                        </LinearLayout>

                        <EditText
                            android:layout_marginTop="3dp"
                            android:layout_width="170dp"
                            android:layout_height="wrap_content"/>

                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textSize="8dp"
                            android:text="Vehice Type   "
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:textColor="#FF0000"
                            android:text="*"
                            android:layout_width="130dp"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <AutoCompleteTextView
                        android:hint=" Search Vehicle Type"
                        android:id="@+id/vehicletype"
                        android:drawableStart="@drawable/search"
                        android:layout_marginTop="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <Button
                    android:layout_marginTop="10dp"
                    android:textSize="11dp"
                    android:text="Add Order Products"
                    android:layout_gravity="center_horizontal"
                    android:layout_width="180dp"
                    android:layout_height="40dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="45dp">
                    <TextView
                        android:layout_marginTop="30dp"
                        android:textSize="11dp"
                        android:layout_marginLeft="150dp"
                        android:text="Total Discount -₹"
                        android:layout_width="wrap_content"
                        android:layout_height="15dp"/>
                    <TextView
                        android:textSize="11dp"
                        android:text="o.oo"
                        android:layout_marginLeft="80dp"
                        android:layout_marginTop="30dp"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="45dp">
                    <TextView
                        android:layout_marginTop="20dp"
                        android:textSize="11dp"
                        android:layout_marginLeft="98dp"
                        android:text="Total Amount (incl. tax) -₹"
                        android:layout_width="wrap_content"
                        android:layout_height="15dp"/>
                    <TextView
                        android:layout_marginLeft="80dp"
                        android:layout_marginTop="20dp"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:visibility="gone"
                android:id="@+id/take1"
                android:orientation="vertical"
                android:layout_marginTop="5dp"
                android:background="@color/white"
                android:layout_width="match_parent"
                android:layout_height="70dp">

               <LinearLayout
                   android:layout_width="match_parent"
                   android:layout_height="wrap_content">
                   <TextView
                       android:textSize="9dp"
                       android:text="Promotional Discount"
                       android:layout_marginTop="10dp"
                       android:layout_width="wrap_content"
                       android:layout_height="10dp"/>
                   <ImageView
                       android:layout_marginLeft="240dp"
                       android:layout_width="35dp"
                       android:layout_height="30dp"
                       android:layout_marginTop="15dp"
                       android:background="#F2F4F6"
                       android:src="@drawable/pen" />
               </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="12dp"
                        android:text="₹ 0.00 (0.0%)"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                </LinearLayout>



            </LinearLayout>

            <LinearLayout
                android:visibility="gone"
                android:id="@+id/take2"
                android:background="@color/white"
                android:layout_marginTop="5dp"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:orientation="vertical">

            </LinearLayout>

            <LinearLayout
                android:visibility="gone"
                android:id="@+id/current"
                android:orientation="vertical"
                android:background="@color/white"
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_marginTop="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp">
                    <TextView
                        android:layout_marginRight="40dp"
                        android:text="Current Stock"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"/>
                    <Spinner
                        android:layout_marginLeft="30dp"
                        android:layout_width="130dp"
                        android:layout_height="match_parent"/>
                    <EditText
                        android:background="@drawable/editextborder"
                        android:gravity="center"
                        android:hint="Qty"
                        android:layout_marginLeft="10dp"
                        android:layout_width="70dp"
                        android:layout_height="match_parent"/>

                </LinearLayout>

                <Button
                    android:layout_marginBottom="10dp"
                    android:layout_marginTop="10dp"
                    android:textSize="11dp"
                    android:text="Add Order Products"
                    android:layout_gravity="center_horizontal"
                    android:layout_width="180dp"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <LinearLayout
                android:visibility="gone"
                android:id="@+id/return1"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:background="@color/white"
                android:layout_width="match_parent"
                android:layout_height="240dp">
                <TextView
                    android:text="Return"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="30dp"/>
                <TextView
                    android:text="products *"
                    android:textSize="9dp"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"/>
                <AutoCompleteTextView
                    android:id="@+id/productsearch"
                    android:drawableStart="@drawable/search"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="30dp"/>
                <LinearLayout
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="50dp">
                    <CheckBox
                        android:id="@+id/pcs"
                        android:text="PCS"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <CheckBox
                        android:id="@+id/box"
                        android:layout_marginLeft="10dp"
                        android:text="BOX"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <Spinner
                        android:layout_marginLeft="30dp"
                        android:layout_width="130dp"
                        android:layout_height="50dp"/>
                    <EditText
                        android:layout_marginLeft="10dp"
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
                <TextView
                    android:layout_marginLeft="260dp"
                    android:text="PCS"
                    android:layout_width="match_parent"
                    android:layout_height="15dp"/>
                <Button
                    android:layout_marginTop="15dp"
                    android:textSize="11dp"
                    android:text="Add Return Products"
                    android:layout_gravity="center_horizontal"
                    android:layout_width="180dp"
                    android:layout_height="40dp"/>

            </LinearLayout>

            <LinearLayout
                android:visibility="gone"
                android:id="@+id/collection"
                android:background="@color/white"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_marginTop="10dp"
                    android:text="Collection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <LinearLayout

                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="35dp">
                    <LinearLayout
                        android:background="@drawable/shape"
                        android:layout_width="115dp"
                        android:layout_height="match_parent">
                        <TextView
                            android:textColor="#5C4080"
                            android:id="@+id/cash"
                            android:layout_width="115dp"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="Cash"
                            android:textSize="8dp" />

                    </LinearLayout>
                    <LinearLayout
                        android:background="@drawable/centerbg"
                        android:layout_width="115dp"
                        android:layout_height="match_parent">
                        <TextView
                            android:textColor="#5C4080"
                            android:id="@+id/banktransfer"
                            android:layout_width="115dp"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="Bank Transfer"
                            android:textSize="8dp" />

                    </LinearLayout>
                    <LinearLayout
                        android:background="@drawable/textviewbgcolor"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">
                        <TextView
                            android:id="@+id/cheque"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:textColor="#5C4080"
                            android:gravity="center"
                            android:text="Cheque"
                            android:textSize="8dp" />
                    </LinearLayout>







                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="8dp"
                        android:text="Payment Date   "
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:textColor="#FF0000"
                        android:text="*"
                        android:layout_width="125dp"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:textSize="8dp"
                        android:text="Amount   "
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:textColor="#FF0000"
                        android:text="*"
                        android:layout_width="125dp"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="200dp"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginTop="10dp"
                                android:paddingLeft="6dp"
                                android:src="@drawable/calendar"/>
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="35dp"/>
                        </LinearLayout>

                        <TextView
                            android:background="@color/black"
                            android:layout_width="190dp"
                            android:layout_height="1dp"/>
                    </LinearLayout>
                    <TextView
                        android:layout_marginTop="5dp"
                        android:layout_marginLeft="10dp"
                        android:text="₹"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <EditText
                        android:layout_marginTop="5dp"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
                <LinearLayout
                    android:id="@+id/chequevisible"
                    android:orientation="vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textSize="8dp"
                            android:text="Cheque Date   "
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:textColor="#FF0000"
                            android:text="*"
                            android:layout_width="130dp"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:textSize="8dp"
                            android:text="Bank Name   "
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:textColor="#FF0000"
                            android:text="*"
                            android:layout_width="125dp"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_marginTop="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="200dp"
                            android:layout_height="match_parent">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_marginTop="10dp"
                                    android:paddingLeft="6dp"
                                    android:src="@drawable/calendar"/>
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="35dp"/>
                            </LinearLayout>

                            <TextView
                                android:background="@color/black"
                                android:layout_width="190dp"

                                android:layout_height="1dp"/>
                        </LinearLayout>

                        <EditText
                            android:layout_marginTop="3dp"
                            android:layout_width="170dp"
                            android:layout_height="wrap_content"/>

                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="8dp"
                        android:text="Reference Number   "
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/refnumber"
                        android:textColor="#FF0000"
                        android:text="*"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                </LinearLayout>
                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <Button
                    android:layout_marginTop="15dp"
                    android:textSize="11dp"
                    android:text="Add Collection"
                    android:layout_gravity="center_horizontal"
                    android:layout_width="180dp"
                    android:layout_height="40dp"/>
                <ImageView
                    android:layout_gravity="center_horizontal"
                    android:layout_width="130dp"
                    android:layout_height="170dp"
                    android:src="@drawable/image"
                    android:scaleType="centerInside"/>



            </LinearLayout>

            <LinearLayout
                android:visibility="gone"
                android:id="@+id/general"
                android:orientation="vertical"
                android:background="@color/white"
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="100dp">

                <TextView
                    android:text="General Visit"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <LinearLayout
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_marginTop="5dp"
                        android:textSize="8dp"
                        android:text="Visit Reason   "
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"/>
                    <TextView
                        android:layout_marginTop="5dp"
                        android:textColor="#FF0000"
                        android:text="*"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                </LinearLayout>
                <AutoCompleteTextView
                    android:id="@+id/visitreason"
                    android:drawableStart="@drawable/search"
                    android:textSize="13dp"
                    android:hint="Search Reason"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

            </LinearLayout>

            <LinearLayout
                android:visibility="gone"
                android:id="@+id/comment"
                android:orientation="vertical"
                android:background="@color/white"
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="90dp">
                <TextView
                    android:layout_marginTop="10dp"
                    android:textSize="8dp"
                    android:text="Comments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <EditText
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"/>

            </LinearLayout>

            <LinearLayout
                android:visibility="gone"
                android:id="@+id/photos"
                android:layout_marginBottom="15dp"
                android:orientation="vertical"
                android:background="@color/white"
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="240dp">
                <TextView
                    android:layout_marginTop="10dp"
                    android:text="Outlet Photos"
                    android:layout_width="match_parent"
                    android:layout_height="30dp"/>
                <LinearLayout
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="10dp"
                        android:gravity="center"
                        android:paddingLeft="10dp"
                        android:text="Outlet Photo"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:textSize="10dp"
                        android:text="Product Photo"
                        android:paddingRight="90dp"
                        android:gravity="center"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_marginLeft="35dp"

                        android:layout_gravity="center_horizontal"
                        android:layout_width="130dp"
                        android:layout_height="170dp"
                        android:src="@drawable/image"
                        android:scaleType="centerInside"/>
                    <ImageView
                        android:layout_marginLeft="25dp"
                        android:layout_width="130dp"
                        android:layout_height="170dp"
                        android:src="@drawable/image"
                        android:scaleType="centerInside"/>
                </LinearLayout>


            </LinearLayout>




        </LinearLayout>
    </ScrollView>

</RelativeLayout>